@startuml
left to right direction

person C [
<b>Cliente</b>
[Person]
---
Fornecedor dos dados.
]

rectangle W [
<b>WhatsApp</b>
[Software System]
---
Serviços do Whatsapp.
]

rectangle Sakura as S {
    rectangle B [
    <b>Backend</b>
    [Container: Java and Spring Boot]
    ---
    Recebe mensagens do cliente.
    ]

    database DB [
    <b>Database</b>
    [Container: Postgres]
    ---
    Todos os registros.
    ]

    database FS [
    <b>Filesystem</b>
    [Container: Filesystem]
    ---
    Imagens.
    ]
}

rectangle VIA [
<b>Vision LLM</b>
[Software System]
---
Serviços de IA para imagem.
]

C ..> W : Envia imagem\ndo Cupom Fiscal
W ..> B : Repassa conteúdo
B ..> VIA : Transforma imagem em texto
B ..> DB : Salva e lê dados
B ..> FS : Salva e lê dados
B ..> W : Devolve informação
W ..> C : Repassa conteúdo
@enduml
